{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Inventory items like speakers and acoustic materials.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "category": { "type": "string", "enum": ["Speakers", "Acoustic Panels", "Cables", "Amplifiers", "Accessories"] },
        "stock": { "type": "number", "description": "Current stock level" },
        "unitPrice": { "type": "number", "description": "Price per unit" },
        "description": { "type": "string", "description": "Product description" }
      },
      "required": ["name", "category", "stock", "unitPrice"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer details and financial summary.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Customer name" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "totalSpent": { "type": "number", "description": "Total amount billed to customer" },
        "outstandingBalance": { "type": "number", "description": "Amount yet to be paid" }
      },
      "required": ["name", "phone"]
    },
    "Project": {
      "title": "Project",
      "description": "Acoustic work or speaker installation project.",
      "type": "object",
      "properties": {
        "customerId": { "type": "string", "description": "Reference to Customer ID" },
        "title": { "type": "string", "description": "Project title" },
        "status": { "type": "string", "enum": ["Quoted", "In-Progress", "Completed", "Billed"] },
        "totalAmount": { "type": "number" },
        "paidAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "title", "status", "totalAmount"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Payment transaction record.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string", "description": "Reference to Project ID" },
        "customerId": { "type": "string", "description": "Reference to Customer ID" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "method": { "type": "string", "enum": ["Cash", "Bank Transfer", "Card", "Cheque"] }
      },
      "required": ["projectId", "customerId", "amount", "date", "method"]
    }
  },
  "firestore": {
    "/products/{productId}": { "schema": "Product", "description": "Inventory collection" },
    "/customers/{customerId}": { "schema": "Customer", "description": "Customer collection" },
    "/projects/{projectId}": { "schema": "Project", "description": "Projects and acoustic works" },
    "/payments/{paymentId}": { "schema": "Payment", "description": "Payment history" }
  }
}
